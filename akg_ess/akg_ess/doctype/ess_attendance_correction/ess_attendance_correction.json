  {"fieldname": "section_decision",  "fieldtype": "Section Break", "label": "Decision"},
  {"fieldname": "approver",          "fieldtype": "Link", "options": "User", "label": "Approver", "read_only": 1},
  {"fieldname": "approver_comment",  "fieldtype": "Small Text", "label": "Approver comment"},
  {"fieldname": "approved_on",       "fieldtype": "Datetime", "label": "Decided on", "read_only": 1},
  {"fieldname": "applied",           "fieldtype": "Check", "label": "Applied", "read_only": 1, "description": "Set once the corrected check-ins have been written and the day recomputed."},
  {"fieldname": "applied_on",        "fieldtype": "Datetime", "label": "Applied on", "read_only": 1},
  {"fieldname": "submitted_on",      "fieldtype": "Datetime", "label": "Submitted on", "read_only": 1}
