  {"fieldname": "section_proposed",  "fieldtype": "Section Break", "label": "Proposed correction", "description": "Fill only what needs fixing. Blank fields are left unchanged."},
  {"fieldname": "in_time",           "fieldtype": "Data", "label": "Check-in time (HH:MM)"},
